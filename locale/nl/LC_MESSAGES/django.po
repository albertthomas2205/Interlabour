# --- OTP verification email ---
msgid "Your verification code - Inter Labour"
msgstr "Je verificatiecode - Inter Labour"

msgid "Inter Labour - your verification code"
msgstr "Inter Labour - jouw verificatiecode"

msgid "Inter Labour"
msgstr "Inter Labour"

msgid "INTER LABOUR"
msgstr "INTER LABOUR"

msgid "Recruitment & staffing agency"
msgstr "Werving & uitzendbureau"

msgid "Hello %(name)s,"
msgstr "Hallo %(name)s,"

msgid "Thank you for registering with"
msgstr "Bedankt voor je registratie bij"

msgid "To confirm your email address, enter the code below on the verification page."
msgstr "Om je e-mailadres te bevestigen, voer je onderstaande code in op de verificatiepagina."

msgid "Your verification code"
msgstr "Je verificatiecode"

msgid ""
"This code is valid for %(minutes)s minutes. Never share the code with "
"anyone - we never ask for it by phone or on social media."
msgstr ""
"Deze code is %(minutes)s minuten geldig. Deel de code nooit met anderen - "
"wij vragen deze nooit telefonisch of via social media."

msgid ""
"If you did not start this registration yourself, you can ignore this email; "
"no account will be activated without this step."
msgstr ""
"Heb je deze aanmelding niet zelf gestart? Dan kun je deze e-mail gewoon "
"negeren; er wordt geen account geactiveerd zonder deze stap."

msgid "Kind regards,"
msgstr "Met vriendelijke groet,"

msgid "The Inter Labour team"
msgstr "Het team van Inter Labour"

msgid "Visit website"
msgstr "Website bezoeken"

msgid ""
"This email was sent automatically by Inter Labour. Replies to this message "
"are not read."
msgstr ""
"Deze e-mail is automatisch verzonden door Inter Labour. Antwoorden op dit "
"bericht worden niet gelezen."
