DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_SECURE_SSL_REDIRECT=False

# Keep empty to use SQLite (backend/db.sqlite3).
DATABASE_URL=

# Set True only for local development.
CORS_ALLOW_ALL_ORIGINS=True

# If CORS_ALLOW_ALL_ORIGINS=False, set explicit origins.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Public site URL used in e-mails and production links.
PUBLIC_SITE_URL=

# Optional bootstrap users for deployment/demo environments.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@gmail.com
DJANGO_SUPERUSER_PASSWORD=admin123
BOOTSTRAP_USER_USERNAME=albert
BOOTSTRAP_USER_EMAIL=albert@gmail.com
BOOTSTRAP_USER_PASSWORD=albert123

# JWT settings
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# OTP settings
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Optional: required only if you want admin registration through API.
ADMIN_REGISTRATION_CODE=

# Email settings (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-zoho-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Inter Labour <no-reply@interlabour.local>

# Zoho relay error 553: use the SMTP hostname for your account datacenter (smtp.zoho.in,
# smtp.zoho.com, or smtp.zoho.eu) and ensure EMAIL_HOST_USER is the exact mailbox you
# authenticate with. The app aligns the visible From address with EMAIL_HOST_USER automatically.

# OTP From: display name + mailbox. Also set EMAIL_HOST_USER to the SAME address (e.g. support@…)
# so Zoho accepts the message — if USER is still info@…, mail will look like it is from info@.
# OTP_FROM_EMAIL=Interlabour <support@interlabour.nl>
# Optional: force mailbox only (overrides e-mail part of OTP_FROM_EMAIL):
# OTP_FROM_MAILBOX=support@interlabour.nl

# Optional: full URL to your logo image for e-mail (PNG or SVG). If empty, uses PUBLIC_SITE_URL + /assets/imgs/theme/logo.svg
# EMAIL_LOGO_URL=

# Separate SMTP identities if you want OTP/support and HR/application e-mails to come from
# different mailboxes. If unset, the app falls back to EMAIL_HOST_USER / EMAIL_HOST_PASSWORD.
# SUPPORT_EMAIL_HOST_USER=support@interlabour.nl
# SUPPORT_EMAIL_HOST_PASSWORD=your-support-app-password
# SUPPORT_FROM_EMAIL=Interlabour <support@interlabour.nl>
# HR_EMAIL_HOST_USER=hr@interlabour.nl
# HR_EMAIL_HOST_PASSWORD=your-hr-app-password
# HR_FROM_EMAIL=Interlabour <hr@interlabour.nl>
# OTP_FROM_EMAIL=Interlabour <support@interlabour.nl>
# OTP_FROM_MAILBOX=support@interlabour.nl
# EMAIL_INLINE_LOGO=True
